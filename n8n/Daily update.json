    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH activated_changed AS (\n  UPDATE creative_status s\n  SET status = 'active'\n  WHERE status = 'changed'\n    AND changed_date < CURRENT_DATE\n    AND EXISTS (\n        SELECT 1\n        FROM creative_snapshots t\n        WHERE t.creative_id = s.creative_id\n          AND t.snapshot_date::date = CURRENT_DATE\n    )\n  RETURNING 1\n)\nSELECT COUNT(*) AS activated_changed_count\nFROM activated_changed;",
        "options": {}
