        "query": "UPDATE creative_status\nSET \n  status = 'changed',\n  changed_date = CAST(\n    '{{ new Date($json.changed_date).toISOString().slice(0, 10) }}' \n    AS date\n  )\nWHERE creative_id = '{{$json.creative_id}}'\n  AND status <> 'removed';",
