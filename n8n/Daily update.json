        "query": "UPDATE creative_status\nSET \n  status = 'removed',\n  became_removed_date = COALESCE(\n    became_removed_date,\n    CAST('{{ new Date($json.became_removed_date).toISOString().slice(0, 10) }}' AS date)\n  )\nWHERE creative_id = '{{$json.creative_id}}';",
