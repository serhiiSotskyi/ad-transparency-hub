    {
      "parameters": {
        "jsCode": "const out = [];\n\nfor (const item of $input.all()) {\n  const ad = item.json;\n\n  const creativeId = ad.creative_id || null;\n  if (!creativeId) continue;\n\n  const advertiserId = ad.advertiser_id || null;\n  const format = ad.format || null;\n\n  let region = null;\n  if (Array.isArray(ad.regions)) {\n    const gbRegion = ad.regions.find((r) => r?.code === 'GB' || r?.region_code === 'GB');\n    if (gbRegion) region = 'GB';\n  }\n  if (!region && ad.url && ad.url.includes('region=GB')) {\n    region = 'GB';\n  }\n  if (region !== 'GB') continue;\n\n  const image = ad.preview_image?.url || null;\n  const videos = Array.isArray(ad.videos)\n    ? ad.videos.map((video) => ({\n        url: video?.url || video?.src || null,\n        height: video?.height || null,\n        width: video?.width || null,\n      })).filter((video) => video.url)\n    : [];\n\n  out.push({\n    json: {\n      creative_id: creativeId,\n      snapshot_date: new Date().toISOString().slice(0, 10),\n      advertiser_id: advertiserId,\n      format,\n      region,\n      image,\n      videos,\n      metadata: {\n        type: ad.type || null,\n        preview_url: ad.preview_url || null,\n      },\n      first_seen: ad.first_shown || null,\n      last_seen_global: ad.last_shown || null,\n      seen_today: true,\n    },\n  });\n}\n\nreturn out;"
      },
