    {
      "parameters": {
        "jsCode": "// Input: an array of items from SearchAPI\n// Output: one transformed item per creative\n\nreturn items.map(item => {\n  const data = item.json;\n\n  return {\n    json: {\n      creative_id: data.creative_id || null,\n      advertiser_id: data.advertiser_id || null,\n      advertiser_name: data.title || null, // best available value from this structure\n\n      first_seen: data.first_shown || null,\n      last_seen_global: data.last_shown || null,\n      format: data.format || null,\n\n      verified: data.verified ?? null,\n      url: data.url || null,\n\n      regions: data.regions\n        ? data.regions.map(r => ({\n            region: r.code || null,\n            name: r.name || null,\n            region_code: r.region_code || null\n          }))\n        : [],\n\n      images: data.preview_image?.url\n        ? [\n            {\n              image: data.preview_image.url,\n              height: data.preview_image.height || null,\n              width: data.preview_image.width || null\n            }\n          ]\n        : [],\n\n      metadata: {\n        type: data.type || null,\n        rank_group: data.rank_group || null,\n        rank_absolute: data.rank_absolute || null,\n        preview_url: data.preview_url || null\n      }\n    }\n  };\n});"
      },
