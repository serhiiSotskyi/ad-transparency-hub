    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH restored_removed AS (\n  UPDATE creative_status s\n  SET status = 'active',\n      became_removed_date = NULL\n  WHERE status = 'removed'\n    AND EXISTS (\n        SELECT 1\n        FROM creative_snapshots t\n        WHERE t.creative_id = s.creative_id\n          AND t.snapshot_date::date = CURRENT_DATE\n    )\n  RETURNING 1\n),\nactivated_new AS (\n  UPDATE creative_status s\n  SET status = 'active'\n  WHERE status = 'new'\n    AND became_new_date <= CURRENT_DATE - INTERVAL '7 days'\n    AND EXISTS (\n        SELECT 1\n        FROM creative_snapshots t\n        WHERE t.creative_id = s.creative_id\n          AND t.snapshot_date::date = CURRENT_DATE\n    )\n  RETURNING 1\n)\nSELECT\n  (SELECT COUNT(*) FROM restored_removed) AS restored_removed_count,\n  (SELECT COUNT(*) FROM activated_new) AS activated_new_count;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
