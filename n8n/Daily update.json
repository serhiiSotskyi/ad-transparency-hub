      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT DISTINCT snaps.creative_id,\n       CURRENT_DATE AS became_new_date\nFROM creative_snapshots snaps\nLEFT JOIN creative_status st ON st.creative_id = snaps.creative_id\nWHERE snaps.snapshot_date::date = CURRENT_DATE\n  AND st.creative_id IS NULL;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
