    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT st.creative_id,\n       CURRENT_DATE AS became_removed_date\nFROM creative_status st\nWHERE st.status <> 'removed'\n  AND NOT EXISTS (\n      SELECT 1\n      FROM creative_snapshots snaps\n      WHERE snaps.creative_id = st.creative_id\n        AND snaps.snapshot_date::date = CURRENT_DATE\n  );",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        1536,
        192
      ],
      "id": "0d692679-064d-4f2d-a6cf-079f74f0eb9d",
      "name": "removed ads",
      "credentials": {
        "postgres": {
          "id": "ObCPWIeUoYLAcV9e",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH today AS (\n  SELECT DISTINCT ON (creative_id) *\n  FROM creative_snapshots\n  WHERE snapshot_date::date = CURRENT_DATE\n  ORDER BY creative_id, snapshot_date DESC, id DESC\n),\nprevious AS (\n  SELECT DISTINCT ON (creative_id) *\n  FROM creative_snapshots\n  WHERE snapshot_date::date < CURRENT_DATE\n  ORDER BY creative_id, snapshot_date DESC, id DESC\n)\nSELECT t.creative_id,\n       CURRENT_DATE AS changed_date\nFROM today t\nJOIN previous y ON y.creative_id = t.creative_id\nJOIN creative_status s ON s.creative_id = t.creative_id\nWHERE s.status <> 'removed'\n  AND (\n       t.media_format IS DISTINCT FROM y.media_format\n    OR COALESCE(t.regions::jsonb, '{}'::jsonb) IS DISTINCT FROM COALESCE(y.regions::jsonb, '{}'::jsonb)\n    OR COALESCE(t.images::jsonb, '{}'::jsonb) IS DISTINCT FROM COALESCE(y.images::jsonb, '{}'::jsonb)\n    OR COALESCE(t.videos::jsonb, '[]'::jsonb) IS DISTINCT FROM COALESCE(y.videos::jsonb, '[]'::jsonb)\n  );",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        1536,
        352
      ],
      "id": "a6137ea7-4c23-44a0-b6ec-e9cc1827ccb0",
      "name": "chnged ads",
      "credentials": {
